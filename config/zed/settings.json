{
  "buffer_font_family": "Berkeley Mono",
  "ui_font_family": "Berkeley Mono",
  "agent_buffer_font_size": 10.5,
  "git_panel": {
    "tree_view": true,
    "dock": "right",
    "collapse_untracked_diff": false,
    "sort_by_path": false,
  },
  "icon_theme": "Zed (Default)",
  "scrollbar": {
    "axes": {
      "vertical": false,
      "horizontal": false,
    },
    "show": "never",
  },
  "window_decorations": "server",
  "use_system_window_tabs": false,
  "preview_tabs": {
    "enabled": true,
    "enable_preview_file_from_code_navigation": true,
    "enable_preview_from_multibuffer": true,
  },
  "tabs": {
    "show_close_button": "hidden",
    "file_icons": true,
    "git_status": true,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_sign_in": true,
    "show_user_menu": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_branch_icon": true,
  },
  "status_bar": {
    "cursor_position_button": true,
  },
  "project_panel": {
    "hide_hidden": false,
    "hide_root": false,
    "indent_guides": {
      "show": "always",
    },
    "sticky_scroll": true,
    "auto_fold_dirs": true,
    "starts_open": true,
    "auto_reveal_entries": true,
    "git_status": true,
    "file_icons": true,
    "folder_icons": true,
    "button": true,
  },
  "terminal": {
    "blinking": "on",
    "cursor_shape": "bar",
    "button": true,
  },
  "agent_ui_font_size": 11.0,
  "buffer_line_height": "comfortable",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "restore_unsaved_buffers": false,
    "trust_all_worktrees": true,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 13.0,
  "buffer_font_size": 10.5,
  "theme": {
    "mode": "dark",
    "light": "batsignal (dark)",
    "dark": "Amoled | Vesper",
  },
  // "languages": {
  //   "C": {
  //     "language_servers": ["clangd"],
  //   },
  //   "SQL": {
  //     "format_on_save": "off",
  //   },
  //   "Rust": {
  //     "formatter": "language_server",
  //     "format_on_save": "on",
  //     "extend_comment_on_newline": false,
  //     "soft_wrap": "none",
  //   },
  //   "Zed": {},
  // },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "active_pane_modifiers": {
    "border_size": 0.0,
    "inactive_opacity": 1.0,
  },
  "restore_on_startup": "launchpad",
  "disable_ai": true,
}
